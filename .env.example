# Copy to .env for local, non-shared setup, or use SOPS via docs/secrets.md.

# GenAI service
GENAI_MODEL_PROVIDER=openai
GENAI_MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=

# For local models via Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Scraping service -> GenAI service
APP_SERVICES_GENAI=http://genai-service:8000

# Azure OpenAI embeddings
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
PGVECTOR_DIMENSIONS=1536

# Vector Search Service database
VECTOR_DB_NAME=vector_search_db
VECTOR_DB_USER=vector_user
VECTOR_DB_PASSWORD=vector_password

# Thesis Service database
THESIS_DB_NAME=thesis_db
THESIS_DB_USER=thesis_user
THESIS_DB_PASSWORD=thesis_password
