# GenAI service
# Set GENAI_USE_OLLAMA=true to use a local Ollama model instead of Azure OpenAI.
GENAI_USE_OLLAMA=false
GENAI_MAX_COMPLETION_TOKENS=30000
AZURE_OPENAI_ENDPOINT=<fill-this>
AZURE_OPENAI_API_KEY=<fill-this>
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Used when GENAI_USE_OLLAMA=true.
GENAI_MODEL_NAME=llama3.1
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Scraping service -> GenAI service
APP_SERVICES_GENAI=http://genai-service:8000
# Azure OpenAI embeddings
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
PGVECTOR_DIMENSIONS=1536
# Vector Search Service database
VECTOR_DB_NAME=vector_search_db
VECTOR_DB_USER=<fill-this>
VECTOR_DB_PASSWORD=<fill-this>
