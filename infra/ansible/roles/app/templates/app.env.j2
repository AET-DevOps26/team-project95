APP_DOMAIN={{ app_domain }}
IMAGE_REPOSITORY={{ image_repository }}
IMAGE_TAG={{ image_tag }}

THESIS_DB_NAME={{ lookup('env', 'THESIS_DB_NAME') | default('thesis_db', true) }}
THESIS_DB_USER={{ lookup('env', 'THESIS_DB_USER') | default('thesis_user', true) }}
THESIS_DB_PASSWORD={{ lookup('env', 'THESIS_DB_PASSWORD') | default('thesis_password', true) }}

VECTOR_DB_NAME={{ lookup('env', 'VECTOR_DB_NAME') | default('vector_search_db', true) }}
VECTOR_DB_USER={{ lookup('env', 'VECTOR_DB_USER') | default('vector_user', true) }}
VECTOR_DB_PASSWORD={{ lookup('env', 'VECTOR_DB_PASSWORD') | default('vector_password', true) }}

CLIENT_CONNECT_TIMEOUT={{ lookup('env', 'CLIENT_CONNECT_TIMEOUT') | default('4000', true) }}
CLIENT_READ_TIMEOUT={{ lookup('env', 'CLIENT_READ_TIMEOUT') | default('300000', true) }}

AZURE_OPENAI_ENDPOINT={{ lookup('env', 'AZURE_OPENAI_ENDPOINT') | default('https://api.openai.com', true) }}
AZURE_OPENAI_API_KEY={{ lookup('env', 'AZURE_OPENAI_API_KEY') | default('dummy-key', true) }}
AZURE_OPENAI_EMBEDDING_DEPLOYMENT={{ lookup('env', 'AZURE_OPENAI_EMBEDDING_DEPLOYMENT') | default('text-embedding-ada-002', true) }}
AZURE_OPENAI_EMBEDDING_MODEL={{ lookup('env', 'AZURE_OPENAI_EMBEDDING_MODEL') | default('text-embedding-ada-002', true) }}
PGVECTOR_DIMENSIONS={{ lookup('env', 'PGVECTOR_DIMENSIONS') | default('1536', true) }}

GENAI_MODEL_PROVIDER={{ lookup('env', 'GENAI_MODEL_PROVIDER') | default('openai', true) }}
GENAI_MODEL_NAME={{ lookup('env', 'GENAI_MODEL_NAME') | default('gpt-4o-mini', true) }}
OPENAI_API_KEY={{ lookup('env', 'OPENAI_API_KEY') | default('', true) }}
OLLAMA_BASE_URL={{ lookup('env', 'OLLAMA_BASE_URL') | default('http://host.docker.internal:11434', true) }}
